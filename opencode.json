{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "secrets/**": "deny"
    },
    "edit": {
      "*": "ask",
      "core/**": "ask",
      "templates/**": "ask",
      "AGENTS.md": "ask",
      "CLAUDE.md": "ask",
      "docs/fablized/**": "ask",
      "adapters/**": "ask",
      ".env": "deny",
      ".env.*": "deny",
      "secrets/**": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "python tools/build.py --check": "allow",
      "python tools/land.py --self-test": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "chmod *": "deny",
      "git push *": "ask"
    },
    "webfetch": "ask"
  }
}
