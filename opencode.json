{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow",
      "AGENTS.md": "ask",
      "CLAUDE.md": "ask",
      "PROTOCOLS.md": "ask",
      "TASK_TEMPLATE.md": "ask",
      "protocols/**": "ask",
      ".env": "deny",
      ".env.*": "deny",
      "secrets/**": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "chmod *": "deny"
    },
    "webfetch": "allow"
  }
}
