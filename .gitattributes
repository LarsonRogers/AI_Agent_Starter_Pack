# Normalize line endings: text files stored as LF in the repo, checked out
# per-platform. Removes the LF/CRLF warnings on Windows working copies.
* text=auto

# Shell scripts must keep LF on every platform — a CRLF shebang (#!/usr/bin/env
# bash\r) fails to execute on Unix. Forces LF checkout even on Windows.
*.sh text eol=lf
