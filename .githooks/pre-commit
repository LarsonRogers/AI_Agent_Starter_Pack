#!/usr/bin/env bash
# .githooks/pre-commit — deterministic commit guard (v13, Amendment 01).
# Enable once per clone:  git config core.hooksPath .githooks
#
# A GATE: exits nonzero on violation and names the rule. Three checks:
#   1. Secrets — staged additions matching known credential formats.
#   2. Size    — staged files over 1MB need explicit intent (SKIP_SIZE_GUARD=1).
#   3. GENERATED files — staged changes to build outputs without a matching
#      core/ or tools/ change mean someone edited a generated file by hand
#      (edit core/, run the build). Override: SKIP_GENERATED_GUARD=1.

set -u

FAIL=0
violate() { printf 'PRE-COMMIT GATE FAILED: %s\n' "$1" >&2; FAIL=1; }

STAGED="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$STAGED" ] && exit 0

# --- 1. secrets in staged additions ---------------------------------------------
SECRET_RE='AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|xox[baprs]-[A-Za-z0-9-]{10,}|sk_(live|test)_[A-Za-z0-9]{10,}|-----BEGIN [A-Z ]*PRIVATE KEY-----'
hits="$(git diff --cached -- . ':(exclude).githooks' ':(exclude)tools/land.sh' \
        | grep -E '^\+' | grep -Ev '^\+\+\+' | grep -E "$SECRET_RE" || true)"
if [ -n "$hits" ]; then
  violate "credential-format string in staged changes (rotate it if real; never commit it):"
  printf '%s\n' "$hits" | head -5 >&2
fi

# --- 2. oversized staged files ----------------------------------------------------
if [ "${SKIP_SIZE_GUARD:-0}" != "1" ]; then
  while IFS= read -r f; do
    sz="$(git cat-file -s ":0:$f" 2>/dev/null || echo 0)"
    if [ "$sz" -gt 1048576 ] 2>/dev/null; then
      violate "staged file over 1MB: $f (${sz} bytes). Large/binary assets need explicit intent — SKIP_SIZE_GUARD=1 to override."
    fi
  done <<EOF
$STAGED
EOF
fi

# --- 3. hand-edits to GENERATED files ----------------------------------------------
if [ "${SKIP_GENERATED_GUARD:-0}" != "1" ]; then
  gen_touched=""
  src_touched=0
  while IFS= read -r f; do
    case "$f" in
      core/*|tools/*) src_touched=1 ;;
      # AGENTS.md is generated BUT its Part 2 is agent-maintained per project
      # (guardrails: "Part 2 project specifics are agent-maintained and exempt")
      # — editing it in a deployed project is sanctioned, so it is not guarded.
      AGENTS.md) continue ;;
    esac
    if git cat-file -p ":0:$f" 2>/dev/null | head -3 | grep -q "GENERATED by tools/build.py"; then
      gen_touched="$gen_touched $f"
    fi
  done <<EOF
$STAGED
EOF
  if [ -n "$gen_touched" ] && [ "$src_touched" -eq 0 ]; then
    violate "GENERATED file(s) staged with no core/ or tools/ change:$gen_touched — edit core/, run 'python tools/build.py', commit both. Override: SKIP_GENERATED_GUARD=1."
  fi
fi

exit "$FAIL"
