#!/usr/bin/env sh
# Thin Git-compatible wrapper around the cross-platform Python guard.
set -eu
ROOT="$(git rev-parse --show-toplevel)"
if python3 -c "import sys" >/dev/null 2>&1; then
  PYTHON=python3
elif python -c "import sys" >/dev/null 2>&1; then
  PYTHON=python
else
  echo "PRE-COMMIT GATE FAILED: Python 3.11+ is required" >&2
  exit 1
fi
exec "$PYTHON" "$ROOT/tools/pre_commit.py"
