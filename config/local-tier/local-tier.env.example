# Copy to ~/.config/fablized/local-tier.env and fill the key outside the repo.
# Strict KEY=VALUE data only: no shell commands, substitutions, or extra keys.
LOCAL_TIER_URL=http://127.0.0.1:8080
LOCAL_TIER_MODEL=replace-with-served-model-id
LOCAL_TIER_API_KEY=replace-outside-repo
LOCAL_TIER_TIMEOUT=300
LOCAL_TIER_LOCK_STALE=900
CANARY_MIN_TOKS=5
CANARY_MAX_TEMP=85
